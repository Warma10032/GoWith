# =============================================================================
# GoWith production env
# Production runs every service in Docker and disables hot reload.
# Copy to `.env.production` and replace every placeholder before deploy.
# =============================================================================

NODE_ENV=production
ENV_FILE=.env.production

# ===== Ports / hosts =====
WEB_HOST=0.0.0.0
WEB_PORT=23000
WEB_HOST_PORT=23000
API_HOST=0.0.0.0
API_PORT=24000
API_HOST_PORT=24000
AI_WORKER_HOST=0.0.0.0
AI_WORKER_PORT=28000
POSTGRES_CONTAINER_PORT=25432
REDIS_CONTAINER_PORT=26379

# ===== Public/internal service URLs =====
PUBLIC_WEB_ORIGIN=https://replace-with-your-domain.example
WEB_ORIGIN=https://replace-with-your-domain.example
NEXT_PUBLIC_SITE_URL=https://replace-with-your-domain.example
NEXT_PUBLIC_API_BASE_URL=https://replace-with-your-api-domain.example
API_BASE_URL=http://api:24000
AI_WORKER_URL=http://ai-worker:28000
DATABASE_URL=postgres://gowith:replace-with-strong-password@postgres:25432/gowith
REDIS_URL=redis://:replace-with-strong-password@redis:26379

# ===== Database & Redis credentials =====
POSTGRES_DB=gowith
POSTGRES_USER=gowith
POSTGRES_PASSWORD=replace-with-strong-password
REDIS_PASSWORD=replace-with-strong-password

# ===== Required production secrets =====
AUTH_SECRET=replace-with-at-least-32-random-bytes
COOKIE_ENCRYPTION_KEY=replace-with-32-byte-base64-key
AI_WORKER_SHARED_SECRET=replace-with-32-byte-shared-secret

# ===== Admin bootstrap =====
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-one-time-strong-password

# ===== Third-party API keys =====
OPENAI_API_KEY=
GROQ_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_SIMPLE_MODEL=MiniMax-M2.7
MINIMAX_COMPLEX_MODEL=MiniMax-M3
MINIMAX_TEMPERATURE=0.1
MINIMAX_MAX_COMPLETION_TOKENS=8192
MINIMAX_REQUEST_TIMEOUT_SECONDS=180
AMAP_WEB_JS_KEY=
AMAP_WEB_SERVICE_KEY=
NEXT_PUBLIC_AMAP_WEB_JS_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

# ===== Bilibili ingest =====
BILIBILI_REQUEST_INTERVAL_MS=1200
BILIBILI_RATE_LIMIT_COOLDOWN_MS=60000
BILIBILI_MAX_REQUEST_INTERVAL_MS=15000
BILIBILI_COMMENTS_LIMIT_PER_VIDEO=80
BILIBILI_MAX_VIDEOS_PER_CREATOR=0
BILIBILI_ASR_ENABLED=true
BILIBILI_CREATOR_PROFILE_REFRESH_MS=21600000
BILIBILI_COOKIE_HEALTH_CHECK_MS=1800000
BILIBILI_COOKIE_EXPIRED_RETENTION_DAYS=30

# ===== ASR =====
GROQ_ASR_MODEL=whisper-large-v3-turbo
GROQ_ASR_MAX_MB=25
ASR_CHUNK_SECONDS=600
ASR_MAX_UPLOAD_MB=26

# ===== Security tunables =====
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=1800000
SESSION_TTL_HOURS=12
CSRF_PROTECTION_ENABLED=true
IMAGE_DOWNLOAD_ALLOWED_DOMAINS=
IMAGE_DOWNLOAD_BLOCK_PRIVATE_NETWORKS=true
