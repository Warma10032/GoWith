{
  "name": "gowith",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:infra && pnpm dev:apps",
    "dev:apps": "concurrently -n web,api,worker,ai -c blue,green,yellow,magenta \"pnpm --filter @gowith/web dev\" \"pnpm --filter @gowith/api dev\" \"pnpm --filter @gowith/worker dev\" \"pnpm dev:ai\"",
    "dev:infra": "docker compose --env-file .env.development -f docker-compose.dev.yml up -d postgres redis",
    "dev:infra:down": "docker compose --env-file .env.development -f docker-compose.dev.yml down",
    "dev:web": "pnpm --filter @gowith/web dev",
    "dev:api": "pnpm --filter @gowith/api dev",
    "dev:worker": "pnpm --filter @gowith/worker dev",
    "dev:ai": "node scripts/run-ai-worker.mjs --reload",
    "docker:prod:build": "docker compose --env-file .env.production -f docker-compose.prod.yml build",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-admin.ts",
    "db:clear": "tsx scripts/clear-data.ts",
    "backfill:images": "tsx scripts/backfill-images.ts",
    "dedupe:shops": "tsx scripts/dedupe-shops-by-poi.ts",
    "backfill:evidence": "tsx scripts/backfill-shop-evidence.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:py": "uv run --project apps/ai-worker --link-mode=copy pytest apps/ai-worker",
    "test:e2e": "playwright test",
    "lint:py": "uv run --project apps/ai-worker --link-mode=copy ruff check apps/ai-worker",
    "typecheck:py": "uv run --project apps/ai-worker --link-mode=copy mypy apps/ai-worker/app",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
