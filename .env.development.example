# =============================================================================
# GoWith development env
# Dev runs only Postgres/Redis in Docker; web/api/worker/ai run locally.
# Copy to `.env.development`.
# =============================================================================

NODE_ENV=development
ENV_FILE=.env.development

# ===== Ports / hosts =====
WEB_HOST=localhost
WEB_PORT=13000
API_HOST=0.0.0.0
API_PORT=14000
AI_WORKER_HOST=0.0.0.0
AI_WORKER_PORT=18000
POSTGRES_HOST=127.0.0.1
POSTGRES_HOST_PORT=15432
POSTGRES_CONTAINER_PORT=5432
REDIS_HOST=127.0.0.1
REDIS_HOST_PORT=16379
REDIS_CONTAINER_PORT=6379

# ===== Local service URLs =====
DATABASE_URL=postgres://gowith:gowith@localhost:15432/gowith
REDIS_URL=redis://:gowith@localhost:16379
WEB_ORIGIN=http://localhost:13000
API_BASE_URL=http://localhost:14000
NEXT_PUBLIC_API_BASE_URL=http://localhost:14000
NEXT_PUBLIC_SITE_URL=http://localhost:13000
AI_WORKER_URL=http://localhost:18000

# ===== Database & Redis credentials =====
POSTGRES_DB=gowith
POSTGRES_USER=gowith
POSTGRES_PASSWORD=gowith
REDIS_PASSWORD=gowith

# ===== Dev secrets =====
AUTH_SECRET=dev-only-auth-secret-change-me
COOKIE_ENCRYPTION_KEY=dev-only-cookie-key-change-me
AI_WORKER_SHARED_SECRET=

# ===== Admin bootstrap =====
ADMIN_EMAIL=admin@gowith.local
ADMIN_INITIAL_PASSWORD=change-me-now

# ===== Third-party API keys =====
OPENAI_API_KEY=
GROQ_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_SIMPLE_MODEL=MiniMax-M2.7
MINIMAX_COMPLEX_MODEL=MiniMax-M3
MINIMAX_TEMPERATURE=0.1
MINIMAX_MAX_COMPLETION_TOKENS=8192
MINIMAX_REQUEST_TIMEOUT_SECONDS=180
AMAP_WEB_JS_KEY=
AMAP_WEB_SERVICE_KEY=
NEXT_PUBLIC_AMAP_WEB_JS_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

# ===== Bilibili ingest =====
BILIBILI_REQUEST_INTERVAL_MS=1200
BILIBILI_RATE_LIMIT_COOLDOWN_MS=60000
BILIBILI_MAX_REQUEST_INTERVAL_MS=15000
BILIBILI_COMMENTS_LIMIT_PER_VIDEO=80
BILIBILI_MAX_VIDEOS_PER_CREATOR=0
BILIBILI_ASR_ENABLED=true
BILIBILI_CREATOR_PROFILE_REFRESH_MS=21600000
BILIBILI_COOKIE_HEALTH_CHECK_MS=1800000
BILIBILI_COOKIE_EXPIRED_RETENTION_DAYS=30

# ===== ASR =====
GROQ_ASR_MODEL=whisper-large-v3-turbo
GROQ_ASR_MAX_MB=25
ASR_CHUNK_SECONDS=600
ASR_MAX_UPLOAD_MB=26

# ===== Security tunables =====
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=1800000
SESSION_TTL_HOURS=720
CSRF_PROTECTION_ENABLED=false
IMAGE_DOWNLOAD_ALLOWED_DOMAINS=
IMAGE_DOWNLOAD_BLOCK_PRIVATE_NETWORKS=true
