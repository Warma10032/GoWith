# =============================================================================
# GoWith .env.example
# 顺序与 .env 保持完全一致;变量值仅作占位符。
# docker compose 强依赖: POSTGRES_PASSWORD / REDIS_PASSWORD / AI_WORKER_SHARED_SECRET
# =============================================================================

# ===== Public connection strings (dev defaults) =====
DATABASE_URL=postgres://gowith:gowith@localhost:15432/gowith
REDIS_URL=redis://localhost:16379

# ===== Required production secrets (NO dev fallback in production) =====
# 用于 session token hash / 客户端指纹
AUTH_SECRET=replace-with-at-least-32-random-bytes
# 用于 AES-256-GCM 加密服务端保存的 B 站 Cookie
COOKIE_ENCRYPTION_KEY=replace-with-32-byte-base64-key
# api / worker / ai-worker 共享;缺失时 worker 调 AI Worker 401
AI_WORKER_SHARED_SECRET=replace-with-32-byte-shared-secret
# 生产必须 production;dev 可省
NODE_ENV=development

# ===== Database & Redis credentials (docker compose 强依赖) =====
# docker-compose.yml 用 ${POSTGRES_PASSWORD:?} 必填占位
POSTGRES_PASSWORD=replace-with-strong-password
# docker-compose.yml 用 ${REDIS_PASSWORD:?} 必填占位
REDIS_PASSWORD=replace-with-strong-password

# ===== Admin bootstrap (dev only; 生产首次登录后必须轮换) =====
ADMIN_EMAIL=admin@gowith.local
ADMIN_INITIAL_PASSWORD=change-me-now

# ===== Third-party API keys =====
OPENAI_API_KEY=
GROQ_API_KEY=
# MiniMax LLM
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_TEMPERATURE=0.1
MINIMAX_MAX_COMPLETION_TOKENS=8192
MINIMAX_REQUEST_TIMEOUT_SECONDS=180
# 高德地图
AMAP_WEB_JS_KEY=
AMAP_WEB_SERVICE_KEY=
# mock = 走固定 fixture;real = 真实 HTTP
EXTERNAL_MODE=mock

# ===== Client endpoints =====
API_BASE_URL=http://localhost:14000
NEXT_PUBLIC_API_BASE_URL=http://localhost:14000
NEXT_PUBLIC_AMAP_WEB_JS_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=
AI_WORKER_URL=http://localhost:18000

# ===== B 站采集策略 =====
BILIBILI_REQUEST_INTERVAL_MS=1200
BILIBILI_COMMENTS_LIMIT_PER_VIDEO=80
BILIBILI_MAX_VIDEOS_PER_CREATOR=0
BILIBILI_ASR_ENABLED=true
BILIBILI_CREATOR_PROFILE_REFRESH_MS=21600000
BILIBILI_COOKIE_HEALTH_CHECK_MS=1800000
BILIBILI_COOKIE_EXPIRED_RETENTION_DAYS=30

# ===== ASR =====
GROQ_ASR_MODEL=whisper-large-v3-turbo
GROQ_ASR_MAX_MB=25
ASR_CHUNK_SECONDS=600
# P1-5: 应用层 ASR 上传 body 兜底;反代 / uvicorn 也应设上限
ASR_MAX_UPLOAD_MB=26

# ===== Security tunables (P0-2 / P0-3 / P2-1) =====
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=1800000
SESSION_TTL_HOURS=720
# 生产自动 true;dev 默认 false;显式设 true 可测试 CSRF 流程
CSRF_PROTECTION_ENABLED=false

# ===== P0-6 image download =====
# 允许下载的图片来源域名(逗号分隔);空 = 允许任何公网域名
IMAGE_DOWNLOAD_ALLOWED_DOMAINS=
# 是否拒绝内网 / 环回 / metadata IP
IMAGE_DOWNLOAD_BLOCK_PRIVATE_NETWORKS=true
