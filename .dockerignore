# Git / build / tooling artefacts that should never enter an image
.git/
.gitignore
.gitattributes
.github/
.claude/
.vscode/
.idea/
*.swp
.DS_Store

# Node / Next / pnpm
node_modules/
.pnpm-store/
.next/
.turbo/
dist/
coverage/
playwright-report/
test-results/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python / uv
.venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Env / secrets / tmp artefacts
.env
.env.*
!.env.example
tmp/
tmp-*.png
logs/
bash.exe.stackdump

# Test fixtures
tests/e2e/playwright-report/
tests/e2e/test-results/
tests/**/coverage/

# Docs not needed at runtime
docs/
README.md
AGENTS.md
CLAUDE.md

# Migrations are loaded by the api service at runtime via
# `pnpm db:migrate`; no need to ship the .sql files in the api
# runtime image. Keep them in the build context for the api-builder
# stage if/when we add a multi-stage Dockerfile (Option B follow-up).
# db/migrations/
